# Multi-period timing analysis via ABC
# Each run checks timing closure at a different clock period
# Same RTL, same library - only the -D parameter changes

read_verilog -sv ../../rtl/fma_fp32_dot3.v
hierarchy -check -top fma_fp32_dot3
proc
opt
techmap
dfflibmap -liberty $::env(SKY130LIB)
abc -liberty $::env(SKY130LIB) -D $::env(CLOCK_PERIOD)
opt
stat -liberty $::env(SKY130LIB)
